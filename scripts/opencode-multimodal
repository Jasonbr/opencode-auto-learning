#!/bin/bash
# OpenCode 多模态记忆工具

set -e

MULTIMODAL_DIR="$HOME/.config/opencode/skills/auto-learning/multimodal"

case "${1:-help}" in
    image|i)
        shift
        echo "🖼️  Processing image..."
        python3 "$MULTIMODAL_DIR/image_ocr.py" "$@"
        ;;
    
    code|c)
        shift
        echo "💻 Processing code..."
        python3 "$MULTIMODAL_DIR/code_indexer.py" "$@"
        ;;
    
    url|u)
        shift
        echo "🌐 Fetching URL..."
        python3 "$MULTIMODAL_DIR/url_fetcher.py" "$@"
        ;;
    
    search|s)
        shift
        TYPE="${1:-all}"
        QUERY="${2:-}"
        
        if [ -z "$QUERY" ]; then
            echo "Usage: opencode-multimodal search <type> <query>"
            echo "Types: image, code, url, all"
            exit 1
        fi
        
        echo "🔍 Searching $TYPE memories for: $QUERY"
        python3 "$MULTIMODAL_DIR/search_multimodal.py" "$TYPE" "$QUERY"
        ;;
    
    help|--help|-h)
        echo "OpenCode 多模态记忆工具"
        echo ""
        echo "Usage:"
        echo "  opencode-multimodal <command> [args]"
        echo ""
        echo "Commands:"
        echo "  image <path> [desc]    Process image with OCR"
        echo "  code <file> [desc]     Index code file"
        echo "  url <url> [desc]       Fetch and index URL content"
        echo "  search <type> <query>  Search multimodal memories"
        echo "  help                   Show this help"
        echo ""
        echo "Examples:"
        echo "  opencode-multimodal image screenshot.png \"Architecture diagram\""
        echo "  opencode-multimodal code script.py \"Deployment script\""
        echo "  opencode-multimodal url https://example.com/article"
        echo "  opencode-multimodal search code \"docker-compose\""
        ;;
    
    *)
        echo "Unknown command: $1"
        echo "Run 'opencode-multimodal help' for usage"
        exit 1
        ;;
esac
